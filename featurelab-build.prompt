'use client'

import Link from 'next/link'
import { motion } from 'framer-motion'
import { ArrowRight, Sparkles, Zap, BarChart3, Brain } from 'lucide-react'

export default function Home() {
  const containerVariants = {
    hidden: { opacity: 0 },
    visible: {
      opacity: 1,
      transition: {
        staggerChildren: 0.2,
        delayChildren: 0.1,
      },
    },
  }

  const itemVariants = {
    hidden: { opacity: 0, y: 20 },
    visible: {
      opacity: 1,
      y: 0,
      transition: { duration: 0.8 },
    },
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-dark via-dark-light to-dark">
      {/* Navigation */}
      <nav className="fixed top-0 w-full z-50 bg-dark/50 backdrop-blur-md border-b border-accent/10">
        <div className="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="flex items-center gap-2"
          >
            <Sparkles className="w-8 h-8 text-accent" />
            <span className="text-2xl font-bold bg-gradient-to-r from-accent to-accent-light bg-clip-text text-transparent">
              FeatureLab
            </span>
          </motion.div>
          <Link
            href="/dashboard"
            className="px-6 py-2 rounded-lg bg-accent hover:bg-accent-light text-dark font-semibold transition-colors"
          >
            Launch App
          </Link>
        </div>
      </nav>

      {/* Hero Section */}
      <motion.section
        variants={containerVariants}
        initial="hidden"
        animate="visible"
        className="min-h-screen flex items-center justify-center pt-20 px-6"
      >
        <div className="text-center max-w-4xl">
          <motion.h1
            variants={itemVariants}
            className="text-6xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-accent via-accent-light to-accent bg-clip-text text-transparent"
          >
            Autonomous ML Feature Engineering
          </motion.h1>

          <motion.p
            variants={itemVariants}
            className="text-xl text-gray-300 mb-8 leading-relaxed"
          >
            Transform raw data into predictive powerhouses. FeatureLab uses AI to autonomously engineer, evaluate, and optimize features for CTR prediction—without human intervention.
          </motion.p>

          <motion.div
            variants={itemVariants}
            className="flex flex-col sm:flex-row gap-4 justify-center"
          >
            <Link
              href="/dashboard"
              className="px-8 py-4 rounded-lg bg-accent hover:bg-accent-light text-dark font-bold text-lg transition-all hover:scale-105 inline-flex items-center justify-center gap-2"
            >
              Start Optimizing <ArrowRight className="w-5 h-5" />
            </Link>
            <button className="px-8 py-4 rounded-lg border border-accent/50 hover:bg-accent/10 text-accent font-bold transition-all">
              Learn More
            </button>
          </motion.div>
        </div>
      </motion.section>

      {/* Features Section */}
      <motion.section
        initial={{ opacity: 0 }}
        whileInView={{ opacity: 1 }}
        className="py-24 px-6 bg-dark-light/50"
      >
        <div className="max-w-7xl mx-auto">
          <h2 className="text-4xl font-bold text-center mb-16">Why FeatureLab?</h2>

          <div className="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {[
              { icon: Brain, title: 'AI-Powered', desc: 'Gemini-driven hypothesis generation' },
              { icon: Zap, title: 'Autonomous', desc: 'Runs without human intervention' },
              { icon: BarChart3, title: 'Data-Driven', desc: 'Evidence-based feature decisions' },
              { icon: Sparkles, title: 'Premium', desc: 'Production-grade code & UI' },
