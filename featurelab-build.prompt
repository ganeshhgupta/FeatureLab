ACTION: Create tools.py (Agent tools implementation)
FILE: tools.py
---
import pandas as pd
import numpy as np
from sklearn.preprocessing import PowerTransformer, KBinsDiscretizer
from sklearn.feature_selection import mutual_info_classif
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import roc_auc_score, log_loss
import lightgbm as lgb
import json

def load_data(path: str) -> pd.DataFrame:
    """Load CSV or Parquet file."""
    if path.endswith('.parquet'):
        return pd.read_parquet(path)
    return pd.read_csv(path)

def profile_feature(df: pd.DataFrame, column: str, target: str = None) -> dict:
    """Comprehensive feature profiling."""
    series = df[column]
    target_series = df[target] if target and target in df.columns else None
    
    profile = {
        "column": column,
        "dtype": str(series.dtype),
        "null_rate": float(series.isnull().sum() / len(series)),
        "cardinality": int(series.nunique()),
        "top_values": series.value_counts().head(5).to_dict() if series.dtype == 'object' else None,
    }
    
    if pd.api.types.is_numeric_dtype(series):
        profile.update({
            "mean": float(series.mean()),
            "std": float(series.std()),
            "min": float(series.min()),
            "max": float(series.max()),
            "skewness": float(series.skew()),
            "kurtosis": float(series.kew()),
        })
    
    if target_series is not None:
        try:
            if pd.api.types.is_numeric_dtype(series):
                profile["correlation_with_target"] = float(series.corr(target_series))
        except:
            profile["correlation_with_target"] = None
    
    return profile

def apply_transformation(df: pd.DataFrame, spec: dict, column: str = None) -> pd.DataFrame:
    """Apply transformation to dataframe."""
    df = df.copy()
    col = column or spec.get("column", spec.get("original_column"))
    
    if spec["type"] == "log1p":
        df[f"{col}_log1p"] = np.log1p(df[col].clip(lower=0))
    elif spec["type"] == "bucketize":
        n_bins = spec.get("n_bins", 10)
        df[f"{col}_bucket"] = pd.cut(df[col], bins=n_bins, labels=False)
    elif spec["type"] == "frequency_encode":
        df[f"{col}_freq"] = df[col].map(df[col].value_counts())
    elif spec["type"] == "clip_outliers":
        p_low, p_high = spec.get("percentiles", [1, 99])
        lower, upper = df[col].quantile([p_low / 100, p_high / 100])
        df[f"{col}_clipped"] = df[col].clip(lower, upper)
    elif spec["type"] == "null_indicator":
        df[f"{col}_isnull"] = df[col].isnull().astype(int)
    
    return df

def evaluate_feature(df: pd.DataFrame, feature: str, target: str) -> dict:
    """Evaluate single feature's predictive power."""
    X = df[[feature]].fillna(df[[feature]].median())
    y = df[target]
    
    # Mutual information
    try:
        mi = mutual_info_classif(X, y, random_state=42)[0]
    except:
        mi = 0.0
    
    # Single-feature LR AUC
    try:
        lr = LogisticRegression(max_iter=1000)
        lr.fit(X, y)
        y_pred = lr.predict_proba(X)[:, 1]
        auc = roc_auc_score(y, y_pred)
    except:
        auc = 0.5
    
    # LightGBM importance
    try:
        train_data = lgb.Dataset(X, label=y)
        params = {"objective": "binary", "verbose": -1, "num_leaves": 31}
        model = lgb.train(params, train_data, num_boost_round=50)
        importance = model.feature_importance()[0]
    except:
        importance = 0.0
    
    return {
        "feature": feature,
        "mutual_information": float(mi),
        "iv_score": float(mi * 100),  # Simplified IV
        "auc_single_feature": float(auc),
        "feature_importance": float(importance),
    }

def compare_baseline(df_original: pd.DataFrame, df_engineered: pd.DataFrame, target: str) -> dict:
    """Train models on both datasets and compare."""
    y = df_original[target]
    
    # Original features
    X_original = df_original.drop(columns=[target])
    train_data_orig = lgb.Dataset(X_original, label=y)
    params = {"objective": "binary", "verbose": -1, "num_leaves": 31, "learning_rate": 0.1}
    model_orig = lgb.train(params, train_data_orig, num_boost_round=100)
    pred_orig = model_orig.predict(X_original)
    auc_orig = roc_auc_score(y, pred_orig)
    loss_orig = log_loss(y, pred_orig)
    
    # Engineered features
    X_engineered = df_engineered.drop(columns=[target])
    train_data_eng = lgb.Dataset(X_engineered, label=y)
    model_eng = lgb.train(params, train_data_eng, num_boost_round=100)
    pred_eng = model_eng.predict(X_engineered)
    auc_eng = roc_auc_score(y, pred_eng)
    loss_eng = log_loss(y, pred_eng)
    
    return {
        "auc_original": float(auc_orig),
        "auc_engineered": float(auc_eng),
        "auc_delta": float((auc_eng - auc_orig) / auc_orig * 100),  # % improvement
        "logloss_original": float(loss_orig),
        "logloss_engineered": float(loss_eng),
        "logloss_delta": float((loss_orig - loss_eng) / loss_orig * 100),  # % improvement
        "original_feature_count": len(X_original.columns),
        "engineered_feature_count": len(X_engineered.columns),
    }

def save_feature_set(df: pd.DataFrame, path: str):
    """Save engineered feature set."""
    df.to_csv(path, index=False)
---

ACTION: Create agent.py (Agentic loop)
FILE: agent.py
---
import pandas as pd
from tools import (
    load_data, profile_feature, apply_transformation, 
    evaluate_feature, compare_baseline, save_feature_set
)
from llm import propose_transformations, explain_decision
from database import SessionLocal, Feature, Experiment
from datetime import datetime
import time

class FeatureEngineeringAgent:
    def __init__(self, evaluation_threshold=0.02, max_iterations=2):
        self.threshold = evaluation_threshold
        self.max_iterations = max_iterations
        self.db = SessionLocal()
        
    def run(self, dataset_path: str, target_column: str, feature_columns: list):
        """Main agent loop."""
        
        # LOAD DATA
        print(f"[AGENT] Loading dataset: {dataset_path}")
        df = load_data(dataset_path)
        df_engineered = df.copy()
        
        # Create experiment record
        experiment = Experiment(
            dataset_name=dataset_path,
            target_column=target_column,
            total_features=len(feature_columns),
            status="running"
        )
        self.db.add(experiment)
        self.db.commit()
        exp_id = experiment.id
        
        kept_count = 0
        discarded_count = 0
        
        # PROCESS EACH FEATURE
        for i, col in enumerate(feature_columns):
            print(f"\n[FEATURE {i+1}/{len(feature_columns)}] Processing '{col}'")
            
            # STEP 1: OBSERVE
            print(f"  STEP 1: OBSERVE - Profiling '{col}'")
            profile = profile_feature(df, col, target_column)
            print(f"    - dtype: {profile['dtype']}, cardinality: {profile['cardinality']}")
            print(f"    - null_rate: {profile['null_rate']:.2%}")
            
            # STEP 2: HYPOTHESIZE
            print(f"  STEP 2: HYPOTHESIZE - Proposing transformations")
            transformations = propose_transformations(profile, "CTR prediction for display ads")
            
            best_feature = None
            best_eval = None
            
            for attempt in range(self.max_iterations):
                if attempt >= len(transformations):
                    break
                    
                spec = transformations[attempt]
                print(f"    - Attempt {attempt+1}: {spec.get('name', 'unknown')} ({spec.get('rationale', 'no rationale')})")
                
                # STEP 3: EXECUTE
                print(f"  STEP 3: EXECUTE - Applying transformation")
                try:
                    df_temp = apply_transformation(df, spec, col)
                    transformed_col = [c for c in df_temp.columns if c not in df.columns][0] if len(df_temp.columns) > len(df.columns) else col
                except Exception as e:
                    print(f"    - Transformation failed: {e}")
                    continue
                
                # STEP 4: EVALUATE
                print(f"  STEP 4: EVALUATE - Assessing predictive power")
                try:
                    evaluation = evaluate_feature(df_temp, transformed_col, target_column)
                    print(f"    - MI: {evaluation['mutual_information']:.4f}")
                    print(f"    - AUC: {evaluation['auc_single_feature']:.4f}")
                    print(f"    - IV: {evaluation['iv_score']:.4f}")
                except Exception as e:
                    print(f"    - Evaluation failed: {e}")
                    continue
                
                # STEP 5: DECIDE
                print(f"  STEP 5: DECIDE")
                baseline_eval = evaluate_feature(df, col, target_column)
                improvement = (evaluation['mutual_information'] - baseline_eval['mutual_information']) / max(baseline_eval['mutual_information'], 0.001)
                
                if improvement > self.threshold:
                    print(f"    ✓ KEEP - {improvement*100:.2f}% improvement")
                    
                    # Save to engineered set
                    df_engineered[transformed_col] = df_temp[transformed_col]
                    best_feature = transformed_col
                    best_eval = evaluation
                    kept_count += 1
                    
                    # Log to database
                    feature_record = Feature(
                        experiment_id=exp_id,
                        name=transformed_col,
                        feature_type=spec.get('type'),
                        original_column=col,
                        transformation=spec.get('name'),
                        signal_score=evaluation['mutual_information'],
                        iv_score=evaluation['iv_score'],
                        mutual_information=evaluation['mutual_information'],
                        auc_single_feature=evaluation['auc_single_feature'],
                        status="kept",
                        rationale=explain_decision("keep", evaluation)
                    )
                    self.db.add(feature_record)
                    break
                else:
                    print(f"    ✗ DISCARD - {improvement*100:.2f}% improvement (below {self.threshold*100:.1f}% threshold)")
                    discarded_count += 1
            
            if best_feature is None:
                discarded_count += 1
                feature_record = Feature(
                    experiment_id=exp_id,
                    name=col,
                    feature_type="numeric" if pd.api.types.is_numeric_dtype(df[col]) else "categorical",
                    original_column=col,
                    status="discarded",
                    rationale="No transformation met improvement threshold"
                )
                self.db.add(feature_record)
        
        self.db.commit()
        
        # STEP 8: FINAL COMPARISON
        print(f"\n[AGENT] STEP 8: FINAL COMPARISON")
        print(f"  Features kept: {kept_count}, discarded: {discarded_count}")
        
        try:
            comparison = compare_baseline(df, df_engineered, target_column)
            print(f"  AUC delta: {comparison['auc_delta']:.2f}%")
            print(f"  Log-loss delta: {comparison['logloss_delta']:.2f}%")
            
            # Update experiment
            experiment.features_kept = kept_count
            experiment.features_discarded = discarded_count
            experiment.auc_delta = comparison['auc_delta']
            experiment.logloss_delta = comparison['logloss_delta']
            
            if comparison['auc_delta'] > 1.5:
                print(f"  ✓ Auto-saving feature set (AUC improvement > 1.5%)")
                save_feature_set(df_engineered, f"features_engineered_{exp_id}.csv")
                experiment.status = "completed"
            else:
                print(f"  ⚠ AUC improvement < 1.5%, manual review recommended")
                experiment.status = "completed"
            
            experiment.completed_at = datetime.utcnow()
            self.db.commit()
            
            return {
                "experiment_id": exp_id,
                "status": "success",
                "features_kept": kept_count,
                "features_discarded": discarded_count,
                "auc_delta": comparison['auc_delta'],
                "logloss_delta": comparison['logloss_delta']
            }
        except Exception as e:
            print(f"  Error in final comparison: {e}")
            experiment.status = "failed"
            self.db.commit()
            return {"status": "error", "message": str(e)}
---

ACTION: Create main.py (FastAPI server)
FILE: main.py
---
from fastapi import FastAPI, HTTPException, Depends
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse
from sqlalchemy.orm import Session
from dotenv import load_dotenv
import os
import asyncio
from datetime import datetime

from database import init_db, get_db, Experiment, Feature
from models import AgentRunRequest, ExperimentResult, FeatureResponse
from agent import FeatureEngineeringAgent
from embedding import clear_index

load_dotenv()
init_db()

app = FastAPI(
    title="FeatureLab API",
    description="Autonomous Feature Engineering Agent for CTR Prediction",
    version="1.0.0"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/health")
async def health_check():
    """Health check endpoint."""
    return {
        "status": "healthy",
        "timestamp": datetime.utcnow().isoformat(),
        "service": "FeatureLab Backend"
    }

@app.post("/api/agent/run")
async def run_agent(request: AgentRunRequest, db: Session = Depends(get_db)):
    """Trigger autonomous feature engineering agent."""
    try:
        agent = FeatureEngineeringAgent(
            evaluation_threshold=request.evaluation_threshold,
            max_iterations=request.max_iterations_per_feature
        )
        
        result = agent.run(
            dataset_path=request.dataset_path,
            target_column=request.target_column,
            feature_columns=request.feature_columns
        )
        
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/api/experiments")
async def get_experiments(db: Session = Depends(get_db)):
    """Get all experiments."""
    experiments = db.query(Experiment).all()
    return experiments

@app.get("/api/experiments/{exp_id}")
async def get_experiment(exp_id: int, db: Session = Depends(get_db)):
    """Get experiment details."""
    experiment = db.query(Experiment).filter(Experiment.id == exp_id).first()
    if not experiment:
        raise HTTPException(status_code=404, detail="Experiment not found")
    return experiment

@app.get("/api/experiments/{exp_id}/features")
async def get_experiment_features(exp_id: int, db: Session = Depends(get_db)):
    """Get features for an experiment."""
    features = db.query(Feature).filter(Feature.experiment_id == exp_id).all()
    return features

@app.get("/api/features")
async def get_features(db: Session = Depends(get_db)):
    """Get all engineered features."""
    features = db.query(Feature).all()
    return features

@app.post("/api/clear")
async def clear_data(db: Session = Depends(get_db)):
    """Clear all data (dev only)."""
    db.query(Feature).delete()
    db.query(Experiment).delete()
    db.commit()
    clear_index()
    return {"status": "cleared"}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000, reload=True)
---

