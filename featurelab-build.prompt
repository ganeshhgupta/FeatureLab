ACTION: Create embedding.py (Pinecone integration)
FILE: embedding.py
---
from pinecone import Pinecone
from dotenv import load_dotenv
import os
import json

load_dotenv()

PINECONE_API_KEY = os.getenv("PINECONE_API_KEY")
PINECONE_INDEX = os.getenv("PINECONE_INDEX", "featurelab-dev")

pc = Pinecone(api_key=PINECONE_API_KEY)

def get_or_create_index():
    try:
        index = pc.Index(PINECONE_INDEX)
        index.describe_index_stats()
        return index
    except:
        pc.create_index(
            name=PINECONE_INDEX,
            dimension=1536,
            metric="cosine"
        )
        return pc.Index(PINECONE_INDEX)

def store_feature_metadata(feature_name: str, metadata: dict, embedding: list):
    index = get_or_create_index()
    index.upsert([(feature_name, embedding, metadata)])

def retrieve_similar_features(embedding: list, top_k: int = 5):
    index = get_or_create_index()
    results = index.query(embedding, top_k=top_k, include_metadata=True)
    return results.get("matches", [])

def clear_index():
    try:
        index = get_or_create_index()
        index.delete(delete_all=True)
    except:
        pass
