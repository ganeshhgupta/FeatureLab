ACTION: Create llm.py (Gemini integration)
FILE: llm.py
---
import google.generativeai as genai
from dotenv import load_dotenv
import os
import json

load_dotenv()

GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")
genai.configure(api_key=GEMINI_API_KEY)
model = genai.GenerativeModel("gemini-pro")

def propose_transformations(feature_profile: dict, task: str) -> list:
    """Use Gemini to reason about optimal transformations."""
    prompt = f"""
You are a feature engineering expert. Given this feature profile and task, propose the top 3 transformations.

Feature Profile:
{json.dumps(feature_profile, indent=2)}

Task: {task}

For each transformation, provide:
1. name (e.g., log1p, bucketize, frequency_encode, target_encode, interaction)
2. type (transformation category)
3. rationale (why this helps for {task})
4. expected_signal_direction (positive/negative/neutral)

Respond ONLY as valid JSON array. No markdown, no code blocks.
"""
    
    response = model.generate_content(prompt)
    try:
        transformations = json.loads(response.text)
        return transformations[:3]  # Top 3
    except:
        return []

def explain_decision(decision: str, evidence: dict) -> str:
    """Generate human-readable explanation for keep/discard decision."""
    prompt = f"""
Explain in 2-3 sentences why this feature was {decision}.

Decision: {decision}
Evidence:
{json.dumps(evidence, indent=2)}

Be concise and cite metrics.
"""
    
    response = model.generate_content(prompt)
    return response.text

def generate_hypothesis(profile: dict, transformation: dict) -> str:
    """Generate hypothesis for why a transformation should work."""
    prompt = f"""
Given this feature profile and transformation, generate a brief hypothesis (1-2 sentences) for why this transformation will improve signal.

Profile: {json.dumps(profile)}
Transformation: {json.dumps(transformation)}
"""
    
    response = model.generate_content(prompt)
    return response.text
