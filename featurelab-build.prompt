ACTION: Create models.py (Pydantic schemas)
FILE: models.py
---
from pydantic import BaseModel
from typing import Optional, List, Dict, Any
from datetime import datetime

class TransformationSpec(BaseModel):
    name: str
    type: str
    rationale: str
    expected_signal_direction: str
    parameters: Optional[Dict[str, Any]] = None

class FeatureProfile(BaseModel):
    column: str
    dtype: str
    null_rate: float
    cardinality: int
    mean: Optional[float] = None
    std: Optional[float] = None
    min: Optional[float] = None
    max: Optional[float] = None
    top_values: Optional[List] = None
    skewness: Optional[float] = None
    kurtosis: Optional[float] = None
    correlation_with_target: Optional[float] = None

class FeatureEvaluation(BaseModel):
    feature: str
    mutual_information: float
    iv_score: float
    auc_single_feature: float
    feature_importance: Optional[float] = None

class AgentRunRequest(BaseModel):
    dataset_path: str
    target_column: str
    feature_columns: List[str]
    evaluation_threshold: float = 0.02
    max_iterations_per_feature: int = 2

class ExperimentResult(BaseModel):
    experiment_id: int
    auc_delta: float
    logloss_delta: float
    features_kept: int
    features_discarded: int
    status: str
    created_at: datetime

class FeatureResponse(BaseModel):
    id: int
    name: str
    feature_type: str
    signal_score: float
    status: str
    rationale: Optional[str] = None
    created_at: datetime
