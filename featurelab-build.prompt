ACTION: Create app/dashboard/page.tsx
FILE: app/dashboard/page.tsx
---
'use client'

import { useState } from 'react'
import { useRouter } from 'next/navigation'
import axios from 'axios'
import { motion } from 'framer-motion'
import { Upload, Loader2, CheckCircle, XCircle } from 'lucide-react'

interface RunState {
  status: 'idle' | 'running' | 'completed' | 'error'
  message?: string
  results?: any
}

export default function Dashboard() {
  const router = useRouter()
  const [file, setFile] = useState<File | null>(null)
  const [targetColumn, setTargetColumn] = useState('')
  const [state, setState] = useState<RunState>({ status: 'idle' })

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files?.[0]) {
      setFile(e.target.files[0])
    }
  }

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!file || !targetColumn) {
      alert('Please upload a file and specify target column')
      return
    }

    setState({ status: 'running', message: 'Initializing agent...' })

    try {
      const response = await axios.post(
        `${process.env.NEXT_PUBLIC_API_URL}/api/agent/run`,
        {
          dataset_path: file.name,
          target_column: targetColumn,
          feature_columns: ['I1', 'I2', 'I3', 'C1', 'C2'],
          evaluation_threshold: 0.02,
          max_iterations_per_feature: 2,
        }
      )

      setState({
        status: 'completed',
        results: response.data,
      })
    } catch (error) {
      setState({
        status: 'error',
        message: error instanceof Error ? error.message : 'Unknown error',
      })
    }
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-dark via-dark-light to-dark py-20 px-6">
      <div className="max-w-4xl mx-auto">
        <motion.div
          initial={{ opacity: 0, y: -20 }}
          animate={{ opacity: 1, y: 0 }}
          className="mb-12"
        >
          <h1 className="text-4xl font-bold mb-2">Feature Engineering Agent</h1>
          <p className="text-gray-400">Upload your dataset to start autonomous feature optimization</p>
        </motion.div>

        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          className="bg-dark-light border border-accent/20 rounded-xl p-8"
        >
          {state.status === 'idle' && (
            <form onSubmit={handleSubmit} className="space-y-6">
              <div>
                <label className="block text-sm font-medium mb-2">Dataset File (CSV)</label>
                <div className="border-2 border-dashed border-accent/30 rounded-lg p-8 text-center cursor-pointer hover:border-accent/60 transition-colors">
                  <input
                    type="file"
                    accept=".csv"
                    onChange={handleFileChange}
                    className="hidden"
                    id="file-input"
                  />
                  <label htmlFor="file-input" className="cursor-pointer">
                    <Upload className="w-8 h-8 mx-auto mb-2 text-accent" />
                    <p className="text-gray-300">
                      {file ? file.name : 'Drop file or click to upload'}
                    </p>
                  </label>
                </div>
              </div>

              <div>
                <label className="block text-sm font-medium mb-2">Target Column</label>
                <input
                  type="text"
                  value={targetColumn}
                  onChange={(e) => setTargetColumn(e.target.value)}
                  placeholder="e.g., click"
                  className="w-full px-4 py-2 bg-dark border border-accent/30 rounded-lg text-white focus:border-accent outline-none transition-colors"
                />
              </div>

              <button
                type="submit"
                className="w-full px-6 py-3 bg-accent hover:bg-accent-light text-dark font-bold rounded-lg transition-colors"
              >
                Start Feature Engineering
              </button>
            </form>
          )}

          {state.status === 'running' && (
            <div className="text-center space-y-6">
              <Loader2 className="w-12 h-12 text-accent mx-auto animate-spin" />
              <div>
                <p className="text-lg font-semibold">{state.message}</p>
                <p className="text-gray-400 mt-2">Agent is autonomously engineering features...</p>
              </div>
            </div>
          )}

          {state.status === 'completed' && (
            <div className="space-y-6">
              <div className="flex items-center gap-3 text-green-400">
                <CheckCircle className="w-6 h-6" />
                <p className="text-lg font-semibold">Feature Engineering Complete!</p>
              </div>

              {state.results && (
                <div className="grid md:grid-cols-2 gap-4">
                  <div className="p-4 bg-dark rounded-lg">
                    <p className="text-sm text-gray-400">Features Kept</p>
                    <p className="text-3xl font-bold text-accent">{state.results.features_kept}</p>
                  </div>
                  <div className="p-4 bg-dark rounded-lg">
                    <p className="text-sm text-gray-400">Features Discarded</p>
                    <p className="text-3xl font-bold text-red-400">{state.results.features_discarded}</p>
                  </div>
                  <div className="p-4 bg-dark rounded-lg">
                    <p className="text-sm text-gray-400">AUC Improvement</p>
                    <p className="text-3xl font-bold text-accent">{state.results.auc_delta.toFixed(2)}%</p>
                  </div>
                  <div className="p-4 bg-dark rounded-lg">
                    <p className="text-sm text-gray-400">Log-Loss Delta</p>
                    <p className="text-3xl font-bold text-accent">{state.results.logloss_delta.toFixed(2)}%</p>
                  </div>
                </div>
              )}

              <button
                onClick={() => setState({ status: 'idle' })}
                className="w-full px-6 py-3 bg-accent hover:bg-accent-light text-dark font-bold rounded-lg transition-colors"
              >
                Try Another Dataset
              </button>
            </div>
          )}

          {state.status === 'error' && (
            <div className="space-y-6">
              <div className="flex items-center gap-3 text-red-400">
                <XCircle className="w-6 h-6" />
                <p className="text-lg font-semibold">Error</p>
              </div>
              <p className="text-gray-400">{state.message}</p>
              <button
                onClick={() => setState({ status: 'idle' })}
                className="w-full px-6 py-3 bg-accent hover:bg-accent-light text-dark font-bold rounded-lg transition-colors"
              >
                Try Again
              </button>
            </div>
          )}
        </motion.div>
      </div>
    </div>
  )
}
---

