OUTPUT FILE 6: FIX_SCRIPT.sh (Automated fixing)
---
#!/bin/bash

echo "🔧 FeatureLab Version Fixer - Running..."

# Backend
echo "📦 Backend: Installing Python 3.11..."
cd backend
python3.11 -m venv venv
source venv/bin/activate
pip install --upgrade pip setuptools wheel
pip install -r requirements.txt
echo "✅ Backend dependencies fixed"

# Frontend
echo "📦 Frontend: Installing Node 20..."
cd ../frontend
nvm install 20.10.0
nvm use 20.10.0
npm install
echo "✅ Frontend dependencies fixed"

# Audit
echo "🔍 Security Audit..."
cd ../backend && pip audit || true
cd ../frontend && npm audit || true

echo "✅ All versions resolved and compatible!"
